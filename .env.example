APP_NAME="BitePlate SRMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tashkent
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ── Logging ───────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=biteplate
DB_USERNAME=biteplate
DB_PASSWORD=biteplate_secret
DB_SCHEMA=public

# ── Redis ─────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Cache ─────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=biteplate_

# ── Queue (Command Pattern uchun) ────────────────────
QUEUE_CONNECTION=redis

# ── Session ───────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Mail ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@biteplate.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Broadcasting ─────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ───────────────────────────────────────
FILESYSTEM_DISK=local

# ── BitePlate Custom Settings ─────────────────────────
BITEPLATE_TAX_RATE=0.20
BITEPLATE_HAPPY_HOUR_DISCOUNT=0.20
BITEPLATE_LOYALTY_DISCOUNT=0.15
BITEPLATE_CURRENCY=GBP
BITEPLATE_CURRENCY_SYMBOL=£
